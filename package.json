{
  "name": "@designofadecade/server",
  "version": "4.2.2",
  "description": "Design of a Decade Server - A modern TypeScript server with WebSocket support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./sanitizer": {
      "types": "./dist/sanitizer/HtmlSanitizer.d.ts",
      "import": "./dist/sanitizer/HtmlSanitizer.js",
      "default": "./dist/sanitizer/HtmlSanitizer.js"
    },
    "./server": {
      "types": "./dist/server/Server.d.ts",
      "import": "./dist/server/Server.js",
      "default": "./dist/server/Server.js"
    },
    "./router": {
      "types": "./dist/router/Router.d.ts",
      "import": "./dist/router/Router.js",
      "default": "./dist/router/Router.js"
    },
    "./logger": {
      "types": "./dist/logger/Logger.d.ts",
      "import": "./dist/logger/Logger.js",
      "default": "./dist/logger/Logger.js"
    },
    "./client": {
      "types": "./dist/client/ApiClient.d.ts",
      "import": "./dist/client/ApiClient.js",
      "default": "./dist/client/ApiClient.js"
    },
    "./context": {
      "types": "./dist/context/Context.d.ts",
      "import": "./dist/context/Context.js",
      "default": "./dist/context/Context.js"
    },
    "./events": {
      "types": "./dist/events/EventsManager.d.ts",
      "import": "./dist/events/EventsManager.js",
      "default": "./dist/events/EventsManager.js"
    },
    "./websocket": {
      "types": "./dist/websocket/WebSocketServer.d.ts",
      "import": "./dist/websocket/WebSocketServer.js",
      "default": "./dist/websocket/WebSocketServer.js"
    },
    "./state": {
      "types": "./dist/state/AppState.d.ts",
      "import": "./dist/state/AppState.js",
      "default": "./dist/state/AppState.js"
    },
    "./utils": {
      "types": "./dist/utils/HtmlRenderer.d.ts",
      "import": "./dist/utils/HtmlRenderer.js",
      "default": "./dist/utils/HtmlRenderer.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "bench": "vitest bench",
    "bench:watch": "vitest bench --watch",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "server",
    "websocket",
    "typescript",
    "node",
    "api",
    "http-server",
    "router",
    "middleware",
    "framework",
    "esm",
    "websocket-server",
    "routing",
    "static-files",
    "html-sanitizer",
    "event-emitter",
    "state-management",
    "openapi",
    "swagger",
    "rest-api"
  ],
  "author": "Design of a Decade <info@designofadecade.com>",
  "license": "MIT",
  "homepage": "https://github.com/designofadecade/server#readme",
  "bugs": {
    "url": "https://github.com/designofadecade/server/issues"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.5",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/designofadecade/server.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix",
      "vitest related --run"
    ]
  }
}
